# Caddy: proxy inverso con HTTPS automático (Let's Encrypt).
johnsalas.online, www.johnsalas.online {
	encode zstd gzip
	reverse_proxy web:3000

	# APKs: forzar descarga con el nombre correcto
	@apk path *.apk
	header @apk Content-Disposition attachment

	header {
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
	}
}
